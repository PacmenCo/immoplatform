// Auth + invite + team schema for Immo
// Using SQLite for dev ergonomics — swap to PostgreSQL via DATABASE_URL in production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  staff
  realtor
  freelancer
}

enum TeamRole {
  owner
  member
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  firstName       String
  lastName        String
  role            String    // Role enum — SQLite doesn't have real enums; validated in app
  phone           String?
  region          String?
  avatarUrl       String?
  bio             String?
  joinedAt        DateTime  @default(now())
  lastSeenAt      DateTime?
  deletedAt       DateTime?
  emailPrefs      String?   // JSON: { eventKey: boolean } — absent key or absent column = default-enabled

  sessions            Session[]
  memberships         TeamMember[]
  sentInvites         Invite[]              @relation("InvitedBy")
  passwordResets      PasswordReset[]
  auditEntries        AuditLog[]            @relation("AuditActor")
  specialties         UserSpecialty[]
  freelancerAssignments Assignment[]        @relation("AssignedFreelancer")
  createdAssignments  Assignment[]          @relation("CreatedAssignment")
  comments            AssignmentComment[]
  uploadedFiles       AssignmentFile[]
  commissionPayoutsMarked CommissionPayout[]
  revenueAdjustmentsCreated RevenueAdjustment[] @relation("RevenueAdjustmentCreator")
  calendarAccounts    CalendarAccount[]

  @@index([role, deletedAt])
  @@map("users")
}

model AssignmentCommission {
  id                    String   @id @default(cuid())
  assignmentId          String   @unique
  teamId                String
  // Snapshots captured at compute time so later Team.commissionValue
  // edits don't rewrite historical lines.
  assignmentTotalCents  Int
  commissionType        String   // "percentage" | "fixed"
  commissionValue       Int      // bps for percentage, cents for fixed
  commissionAmountCents Int
  computedAt            DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId],       references: [id], onDelete: Cascade)

  @@index([teamId, computedAt])
  @@map("assignment_commissions")
}

model CommissionPayout {
  id          String   @id @default(cuid())
  teamId      String
  year        Int
  quarter     Int      // 1-4
  amountCents Int      // snapshot of the quarter total at mark-paid time
  paidAt      DateTime @default(now())
  paidById    String?

  team   Team  @relation(fields: [teamId],   references: [id], onDelete: Cascade)
  paidBy User? @relation(fields: [paidById], references: [id], onDelete: SetNull)

  @@unique([teamId, year, quarter])
  @@index([teamId, year])
  @@map("commission_payouts")
}

model Team {
  id         String   @id @default(cuid())
  name       String
  city       String?
  logo       String?  // 2-letter display
  logoColor  String?
  createdAt  DateTime @default(now())

  // Contact + descriptor
  email             String?   // team-wide contact email (separate from individual members)
  description       String?   // free-form notes

  // Legal / billing (used on invoices)
  legalName         String?
  vatNumber         String?
  kboNumber         String?   // KBO / Chamber of Commerce
  iban              String?
  billingEmail      String?
  billingPhone      String?
  billingAddress    String?
  billingPostal     String?
  billingCity       String?
  billingCountry    String?   @default("Belgium")

  // Branding
  logoUrl              String?
  signatureUrl         String?
  prefersLogoOnPhotos  Boolean @default(false)

  // Invoicing defaults
  defaultClientType String?   // 'owner' | 'firm' — invoice recipient default

  // Commission config
  commissionType    String?   // 'percentage' | 'fixed' | null (no commission)
  commissionValue   Int?      // For percentage: basis points (1500 = 15%); for fixed: cents

  members             TeamMember[]
  invites             Invite[]
  assignments         Assignment[]
  serviceOverrides    TeamServiceOverride[]
  commissionLines     AssignmentCommission[]
  commissionPayouts   CommissionPayout[]
  revenueAdjustments  RevenueAdjustment[]

  @@map("teams")
}

/// Manual revenue adjustments on the financial overview — journal
/// corrections, bonuses, deductions. Per team per calendar month.
/// `amountCents` may be negative for deductions. Admin/staff only.
model RevenueAdjustment {
  id          String   @id @default(cuid())
  teamId      String
  year        Int
  month       Int      // 1-12
  description String
  amountCents Int      // signed — negative = deduction
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team      Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User? @relation("RevenueAdjustmentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([teamId, year, month])
  @@index([year, month])
  @@map("revenue_adjustments")
}

model TeamServiceOverride {
  teamId      String
  serviceKey  String
  priceCents  Int       // overrides Service.unitPrice for this team

  team     Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  service  Service @relation(fields: [serviceKey], references: [key], onDelete: Cascade)

  @@id([teamId, serviceKey])
  @@map("team_service_overrides")
}

model TeamMember {
  teamId    String
  userId    String
  teamRole  String  // TeamRole enum — owner | member
  joinedAt  DateTime @default(now())

  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Invite {
  id            String    @id @default(cuid())
  email         String
  role          String    // Role enum
  teamId        String?
  teamRole      String?   // TeamRole enum, required if teamId set
  tokenHash     String    @unique
  invitedById   String
  note          String?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  acceptedAt    DateTime?
  revokedAt     DateTime?
  resendCount   Int       @default(0)
  lastResentAt  DateTime?

  team          Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy     User      @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([email])
  @@index([tokenHash])
  @@map("invites")
}

model Session {
  id            String    @id           // random 32-byte url-safe string
  userId        String
  activeTeamId  String?
  userAgent     String?
  ip            String?
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordReset {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  usedAt     DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_resets")
}

model AuditLog {
  id          String    @id @default(cuid())
  at          DateTime  @default(now())
  actorId     String?
  verb        String    // created | updated | signed_in | invite.sent | etc.
  objectType  String?
  objectId    String?
  metadata    String?   // JSON blob (SQLite has no JSONB)

  actor       User?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([at])
  @@index([actorId])
  @@index([objectType, objectId])
  @@map("audit_log")
}

// ─── Services catalog ──────────────────────────────────────────────

model Service {
  key         String  @id           // 'epc' | 'asbestos' | 'electrical' | 'fuel'
  label       String                 // 'Energy Performance Certificate'
  short       String                 // 'EPC' | 'AIV' | 'EK' | 'TK'
  color       String                 // CSS variable name, e.g. 'var(--color-epc)'
  description String
  unitPrice   Int                    // cents (euros * 100)
  active      Boolean @default(true)

  assignments  AssignmentService[]
  specialties  UserSpecialty[]
  teamOverrides TeamServiceOverride[]

  @@map("services")
}

model UserSpecialty {
  userId     String
  serviceKey String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceKey], references: [key], onDelete: Cascade)

  @@id([userId, serviceKey])
  @@map("user_specialties")
}

// ─── Assignments ───────────────────────────────────────────────────

model Assignment {
  id               String    @id @default(cuid())
  reference        String    @unique           // 'ASG-2026-1001'
  status           String    // 'draft' | 'scheduled' | 'in_progress' | 'delivered' | 'completed'

  // Property
  address          String
  city             String
  postal           String
  propertyType     String?                     // 'house' | 'apartment' | ...
  constructionYear Int?
  areaM2           Int?

  // Scheduling
  preferredDate    DateTime?
  keyPickup        String?                     // 'owner' | 'tenant' | 'office' | 'lockbox'
  notes            String?

  // Contacts
  ownerName        String
  ownerEmail       String?
  ownerPhone       String?
  tenantName       String?
  tenantEmail      String?
  tenantPhone      String?

  // Relations
  teamId           String?
  freelancerId     String?
  createdById      String?

  // Discount — admin/staff only. Percentage stored as basis points
  // (1500 = 15%); fixed stored as cents.
  discountType        String?   // 'percentage' | 'fixed' | null
  discountValue       Int?
  discountReason      String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deliveredAt         DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?

  // Calendar sync (Platform parity).
  //   googleCalendarEventId  — event on the agency-shared Google calendar
  //                             (written via service account).
  //   outlookCalendarEventId — event on the creator's personal Outlook,
  //                             written via per-user OAuth.
  googleCalendarEventId    String?
  outlookCalendarEventId   String?
  outlookCalendarAccountId String?

  team             Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  freelancer       User?                @relation("AssignedFreelancer", fields: [freelancerId], references: [id], onDelete: SetNull)
  createdBy        User?                @relation("CreatedAssignment", fields: [createdById], references: [id], onDelete: SetNull)
  services         AssignmentService[]
  comments         AssignmentComment[]
  files            AssignmentFile[]
  commission       AssignmentCommission?
  outlookCalendarAccount  CalendarAccount? @relation("OutlookAssignment", fields: [outlookCalendarAccountId], references: [id], onDelete: SetNull)
  personalCalendarEvents  AssignmentCalendarEvent[]

  @@index([status])
  @@index([teamId])
  @@index([freelancerId])
  @@index([createdById])
  @@index([preferredDate])
  @@index([outlookCalendarAccountId])
  @@map("assignments")
}

/// Per-user OAuth connection for external calendar sync.
/// - provider='google' stores access/refresh tokens from google-auth-library.
/// - provider='outlook' stores MSAL's serialized token cache (owns both
///   access + refresh tokens internally).
/// All ciphertext columns use AES-GCM with `CALENDAR_ENCRYPTION_KEY`.
model CalendarAccount {
  id                   String   @id @default(cuid())
  userId               String
  provider             String                          // 'google' | 'outlook'
  providerAccountEmail String
  accessTokenCipher    String?
  refreshTokenCipher   String?
  msalCacheCipher      String?
  expiresAt            DateTime?
  scope                String
  disconnectedAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlookAssignments   Assignment[]              @relation("OutlookAssignment")
  personalEvents       AssignmentCalendarEvent[]

  @@unique([userId, provider])
  @@index([provider, disconnectedAt])
  @@map("calendar_accounts")
}

/// Per-user personal-calendar event ids. Today only filled by the "Add to
/// my Google calendar" flow; later reschedules/cancels loop these rows so
/// every personal copy stays in sync with the agency event.
model AssignmentCalendarEvent {
  id                String   @id @default(cuid())
  assignmentId      String
  calendarAccountId String
  providerEventId   String
  lastSyncedAt      DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignment        Assignment      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  calendarAccount   CalendarAccount @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, calendarAccountId])
  @@index([assignmentId])
  @@map("assignment_calendar_events")
}

model AssignmentService {
  assignmentId    String
  serviceKey      String
  // Price snapshot taken at the moment the assignment was created so
  // retroactive price list changes don't alter in-flight invoices.
  // Backfill migration seeds existing rows from TeamServiceOverride
  // falling back to Service.unitPrice.
  unitPriceCents  Int      @default(0)

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceKey], references: [key])

  @@id([assignmentId, serviceKey])
  @@map("assignment_services")
}

model AssignmentComment {
  id           String   @id @default(cuid())
  assignmentId String
  authorId     String?                // null = system comment
  authorLabel  String?                // 'System' display when authorId null
  body         String
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  author     User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([assignmentId, createdAt])
  @@map("assignment_comments")
}

model AssignmentFile {
  id           String    @id @default(cuid())
  assignmentId String
  uploaderId   String?                // SetNull on user delete — preserve history
  lane         String                 // 'freelancer' | 'realtor'
  storageKey   String                 // opaque, owned by Storage impl
  originalName String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  uploader   User?      @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([assignmentId, lane, deletedAt])
  @@index([uploaderId])
  @@map("assignment_files")
}
