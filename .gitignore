# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# auth / db
/prisma/dev.db
/prisma/dev.db-journal
.env
.env.local

# local file storage (dev)
/storage
.claude/

# playwright-mcp test artifacts (console logs + accessibility-tree dumps)
/.playwright-mcp/
# playwright test runner artifacts (HTML reports + traces with embedded RSC payloads)
/test-results/
/playwright-report/
/invite-full.yml

# QA screenshots dropped at repo root by ad-hoc playwright/test sessions
# (root-only — keeps public/*.png and src/**/*.png trackable)
/*.png
